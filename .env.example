# === Required secrets (replace in .env) ===
POSTGRES_PASSWORD=change_me_postgres
ODOO_ADMIN_PASSWD=change_me_admin

# === Database ===
POSTGRES_USER=odoo
POSTGRES_DB=postgres
DB_NAME=odoo_dev

# === OCA repos pinned to commit SHA (19.0 branch) ===
# Find latest SHA per repo at https://github.com/OCA/<repo>/commits/19.0
# The entrypoint clones OCA/<repo> at this branch and checks out the per-repo
# SHA below. Override OCA_BRANCH here if you need to pin a different branch.
OCA_BRANCH=19.0
OCA_WEB_COMMIT=0000000000000000000000000000000000000000
OCA_WEBSITE_COMMIT=0000000000000000000000000000000000000000
OCA_E_COMMERCE_COMMIT=0000000000000000000000000000000000000000
OCA_SALE_WORKFLOW_COMMIT=0000000000000000000000000000000000000000
OCA_ACCOUNT_FINANCIAL_TOOLS_COMMIT=0000000000000000000000000000000000000000
OCA_STOCK_LOGISTICS_WORKFLOW_COMMIT=0000000000000000000000000000000000000000
OCA_MANAGEMENT_SYSTEM_COMMIT=0000000000000000000000000000000000000000
OCA_SERVER_UX_COMMIT=0000000000000000000000000000000000000000
OCA_SERVER_TOOLS_COMMIT=0000000000000000000000000000000000000000

# === HTTP / network ===
ODOO_HTTP_INTERFACE=0.0.0.0
ODOO_HTTP_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# === Day 3 RAG API (rag-api service in docker-compose.yml) ===
RAG_HTTP_PORT=9000
# sentence-transformers model name; switch to a hosted Voyage model only when
# an API key is available.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === Day 7: unified AI API (steamships-ai-api service) ===
# Hostnames point at the renamed `ai-api` service. The Docker network keeps
# a `rag-api` alias so older references keep resolving during the migration.
AI_API_PORT=9000
AI_API_TOKEN=change-me-local-dev
RAG_API_BASE=http://ai-api:9000
OCR_API_BASE=http://ai-api:9000
RAG_RETRIEVE_TIMEOUT=20

# === RAG ===
CHROMA_PATH=/data/chroma
COLLECTION_NAME=steamships_rag
DOCS_PATH=/docs/mock/rag_documents
MANIFEST_PATH=/docs/mock/rag_documents/MANIFEST_ingestion_metadata.json
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5

# === LLM ===
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# === Gmail SMTP (used for outbound mail server config in Settings) ===
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your_email@gmail.com
MAIL_SMTP_PASSWORD=your_gmail_app_password
MAIL_SMTP_FROM=your_email@gmail.com
MAIL_SMTP_FROM_NAME=IELTS Training App

# === Day 6: Gemini Vision AI fallback for OCR ===
# Set VISION_AI_ENABLED=true and supply GEMINI_API_KEY to enable.
VISION_AI_ENABLED=false
VISION_AI_PROVIDER=gemini
VISION_AI_MODEL=gemini-3-flash-preview
VISION_AI_FALLBACK_MODEL=gemini-3.1-flash-lite
VISION_AI_TIMEOUT_S=90
GEMINI_API_KEY=

# Per-document-type fallback toggles. By default B/L may use AI fallback,
# invoices stay Python-only. Flip on explicitly to opt in.
VISION_AI_ENABLE_BOL=true
VISION_AI_ENABLE_INVOICE=false

# Odoo uses this to reach the OCR FastAPI service inside the docker network.
DOCUMENT_AI_URL=http://document-ai:9100
