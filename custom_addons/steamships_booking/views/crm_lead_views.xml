<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Add "Booking Link" button on crm.lead form view.
             Inherits the standard CRM lead form (crm.crm_lead_view_form).
             Uses a header button with a JS prompt fallback since the
             public URL is generated from the current lead id and base URL.
             ============================================================ -->
        <record id="view_crm_lead_form_booking_link" model="ir.ui.view">
            <field name="name">crm.lead.form.steamships.booking</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <!-- Inject after the standard header_actions / button_box
                     by placing a "Booking Link" button into the header. -->
                <xpath expr="//header" position="inside">
                    <button name="action_copy_booking_link"
                            type="object"
                            string="Booking Link"
                            class="btn-secondary"
                            title="Open the public Steamships booking page for this lead."/>
                </xpath>

                <!-- Add a copy-to-clipboard helper inside the button_box so the
                     URL is visible right under the status bar. -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_copy_booking_link"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-calendar-plus-o"
                            string="Booking Page"
                            title="Copy or open the public booking URL."/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
