<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- Bill of Lading OCR Records                                     -->
    <!-- ============================================================ -->

    <record id="view_steamships_bill_lading_tree" model="ir.ui.view">
        <field name="name">steamships.bill.lading.tree</field>
        <field name="model">steamships.bill.lading</field>
        <field name="arch" type="xml">
            <list string="Bill of Lading OCR Reviews"
                  create="0"
                  decoration-info="state == 'pending_review'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="bl_number"/>
                <field name="shipper"/>
                <field name="consignee"/>
                <field name="vessel_name"/>
                <field name="port_of_loading"/>
                <field name="port_of_discharge"/>
                <field name="overall_confidence" widget="badge"
                       decoration-info="overall_confidence == 'high'"
                       decoration-warning="overall_confidence == 'medium'"
                       decoration-danger="overall_confidence == 'low'"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending_review'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
                <field name="create_date"/>
                <field name="reviewer_id" widget="many2one_avatar_user"/>
                <field name="approved_date"/>
            </list>
        </field>
    </record>

    <record id="view_steamships_bill_lading_search" model="ir.ui.view">
        <field name="name">steamships.bill.lading.search</field>
        <field name="model">steamships.bill.lading</field>
        <field name="arch" type="xml">
            <search string="Bill of Lading OCR Reviews">
                <field name="name" string="Reference"/>
                <field name="bl_number" string="B/L Number"/>
                <field name="shipper"/>
                <field name="consignee"/>
                <field name="vessel_name"/>
                <field name="container_numbers"/>
                <separator/>
                <filter string="Pending Review"
                        name="filter_pending_review"
                        domain="[('state', '=', 'pending_review')]"/>
                <filter string="Approved"
                        name="filter_approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected"
                        name="filter_rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <group>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Reviewer" name="group_reviewer"
                            context="{'group_by': 'reviewer_id'}"/>
                    <filter string="Created On" name="group_create_date"
                            context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_steamships_bill_lading_form" model="ir.ui.view">
        <field name="name">steamships.bill.lading.form</field>
        <field name="model">steamships.bill.lading</field>
        <field name="arch" type="xml">
            <form string="Bill of Lading OCR Review" create="0">
                <header>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-primary"
                            invisible="state != 'pending_review'"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-secondary"
                            invisible="state != 'pending_review'"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_review,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group string="Review Notes" name="review_notes">
                        <field name="overall_confidence" widget="badge"
                               decoration-info="overall_confidence == 'high'"
                               decoration-warning="overall_confidence == 'medium'"
                               decoration-danger="overall_confidence == 'low'"/>
                        <field name="low_confidence_notes" placeholder="No low-confidence warnings"/>
                    </group>

                    <group string="Extracted Bill of Lading Fields" name="extracted">
                        <group>
                            <field name="bl_number"/>
                            <field name="shipper"/>
                            <field name="consignee"/>
                            <field name="notify_party"/>
                        </group>
                        <group>
                            <field name="vessel_name"/>
                            <field name="voyage_number"/>
                            <field name="container_numbers"
                                   placeholder="ABCU1234567, ABCU7654321"/>
                            <field name="document_date"/>
                        </group>
                        <group>
                            <field name="port_of_loading"/>
                            <field name="port_of_discharge"/>
                            <field name="place_of_acceptance"/>
                            <field name="place_of_delivery"/>
                        </group>
                        <group>
                            <field name="weight"/>
                            <field name="measurement"/>
                            <field name="freight_terms"/>
                            <field name="delivery_agent"/>
                        </group>
                    </group>

                    <group string="Cargo Details" name="cargo_details" colspan="4">
                        <field name="cargo_description" widget="text" colspan="4"
                               placeholder="Description of cargo"/>
                        <field name="reference_invoice_number"
                               placeholder="e.g. INV-2025-0042 (if the B/L references an invoice)"/>
                    </group>

                    <group string="Review Trail" name="review_trail">
                        <group>
                            <field name="reviewer_id" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Original Document" name="original_doc">
                            <group>
                                <field name="original_filename" readonly="1"/>
                                <field name="original_mimetype" readonly="1"/>
                                <field name="original_file" filename="original_filename"
                                       readonly="1"/>
                            </group>
                        </page>
                        <page string="Raw OCR Text" name="raw_text">
                            <field name="raw_ocr_text" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Raw JSON" name="raw_json">
                            <field name="raw_json" readonly="1" nolabel="1"
                                   widget="ace" options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action: default filter = Pending Review; user can clear it. -->
    <record id="action_steamships_bill_lading" model="ir.actions.act_window">
        <field name="name">Bill of Lading OCR Reviews</field>
        <field name="res_model">steamships.bill.lading</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_steamships_bill_lading_tree"/>
        <field name="search_view_id" ref="view_steamships_bill_lading_search"/>
        <field name="context">{'search_default_filter_pending_review': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Bill of Lading OCR records yet.
            </p>
            <p>
                Upload a Bill of Lading via <em>Document AI &gt; Upload Document for OCR</em>
                to start. Approved records will appear here once you mark them.
            </p>
        </field>
    </record>
</odoo>
