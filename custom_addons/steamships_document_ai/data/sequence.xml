<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_steamships_bill_lading" model="ir.sequence">
            <field name="name">Steamships Bill of Lading</field>
            <field name="code">steamships.bill.lading</field>
            <field name="prefix">BOL/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_steamships_invoice_ocr" model="ir.sequence">
            <field name="name">Steamships Invoice OCR</field>
            <field name="code">steamships.invoice.ocr</field>
            <field name="prefix">INV-OCR/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
