<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Demo quotations — 3 sale.order records:
               1. QUO-DEMO-001 — Shipping FCL 20ft + LCL, no discount
               2. QUO-DEMO-002 — Property office lease (standard)
               3. QUO-DEMO-003 — Hotel suite, 15% discount → triggers
                                  sale.order.approval.request workflow
             Per DOCX §4 Day 2 demo: "3 quotations with 1 at 15%
             discount to show approval flow".
             ============================================================ -->

        <!-- Quotation 1: Shipping — lead_001 (Marienburg Mining) -->
        <record id="demo_quotation_shipping" model="sale.order">
            <field name="name">QUO-DEMO-001</field>
            <field name="partner_id" ref="lead_partners_demo"/>
            <field name="user_id" ref="user_ship_sales"/>
            <field name="team_id" ref="crm_team_shipping"/>
            <field name="origin">Lead lead_001</field>
            <field name="opportunity_id" ref="lead_001"/>
            <field name="pricelist_id" ref="pricelist_pgk_standard"/>
            <field name="currency_id" ref="base.PGK"/>
            <field name="company_id" ref="res_company_steamships"/>
            <field name="x_division_id" ref="division_shipping"/>
            <field name="x_branch_id" ref="branch_lae"/>
            <field name="date_order" eval="(datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="state">draft</field>
            <field name="note">Monthly FCL shipping contract — Marienburg Mining. Volume: 4× 20ft/month + 30 CBM LCL. Standard pricing applies.</field>
            <field name="order_line" eval="[
                (0, 0, {
                    'product_id': ref('product_fcl_20'),
                    'product_uom_qty': 4,
                    'price_unit': 4500.0,
                    'discount': 0.0,
                }),
                (0, 0, {
                    'product_id': ref('product_lcl'),
                    'product_uom_qty': 30,
                    'price_unit': 280.0,
                    'discount': 0.0,
                }),
                (0, 0, {
                    'product_id': ref('product_stevedoring'),
                    'product_uom_qty': 88,
                    'price_unit': 85.0,
                    'discount': 0.0,
                }),
            ]"/>
        </record>

        <!-- Quotation 2: Property — lead_002 (Australian High Commission) -->
        <record id="demo_quotation_property" model="sale.order">
            <field name="name">QUO-DEMO-002</field>
            <field name="partner_id" ref="lead_partner_embassy"/>
            <field name="user_id" ref="user_prop_sales"/>
            <field name="team_id" ref="crm_team_property"/>
            <field name="origin">Lead lead_002</field>
            <field name="opportunity_id" ref="lead_002"/>
            <field name="pricelist_id" ref="pricelist_pgk_standard"/>
            <field name="currency_id" ref="base.PGK"/>
            <field name="company_id" ref="res_company_steamships"/>
            <field name="x_division_id" ref="division_property"/>
            <field name="x_branch_id" ref="branch_pom"/>
            <field name="date_order" eval="(datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="state">draft</field>
            <field name="note">Grade A office 350 sqm, 24-month lease, CBD Port Moresby. Includes parking 4 bays, 24/7 access, backup power.</field>
            <field name="order_line" eval="[
                (0, 0, {
                    'product_id': ref('product_office_a'),
                    'product_uom_qty': 350,
                    'price_unit': 95.0,
                    'discount': 0.0,
                }),
                (0, 0, {
                    'product_id': ref('product_warehouse'),
                    'product_uom_qty': 50,
                    'price_unit': 45.0,
                    'discount': 0.0,
                }),
            ]"/>
        </record>

        <!-- Quotation 3: Hotel with 15% discount → triggers approval flow.
             Per sale_order_approval.py: discount > 10% blocks action_confirm
             until approval_state == 'approved'.
             Demo path: try to confirm → see UserError → request approval. -->
        <record id="demo_quotation_hotel_discount" model="sale.order">
            <field name="name">QUO-DEMO-003</field>
            <field name="partner_id" ref="lead_partner_bsp"/>
            <field name="user_id" ref="user_hotel_sales"/>
            <field name="team_id" ref="crm_team_hotels"/>
            <field name="origin">Lead lead_003</field>
            <field name="opportunity_id" ref="lead_003"/>
            <field name="pricelist_id" ref="pricelist_pgk_jv"/>
            <field name="currency_id" ref="base.PGK"/>
            <field name="company_id" ref="res_company_steamships"/>
            <field name="x_division_id" ref="division_hotels"/>
            <field name="x_branch_id" ref="branch_pom"/>
            <field name="date_order" eval="(datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="state">draft</field>
            <field name="note">BSP corporate rate — annual contract. 15% discount applied (above 10% threshold, requires Sales Manager approval). Demo: try Confirm → see blocker → click Request Approval.</field>
            <field name="order_line" eval="[
                (0, 0, {
                    'product_id': ref('product_suite_room'),
                    'product_uom_qty': 200,
                    'price_unit': 1450.0,
                    'discount': 15.0,
                }),
                (0, 0, {
                    'product_id': ref('product_std_room'),
                    'product_uom_qty': 400,
                    'price_unit': 650.0,
                    'discount': 15.0,
                }),
                (0, 0, {
                    'product_id': ref('product_conference'),
                    'product_uom_qty': 12,
                    'price_unit': 2500.0,
                    'discount': 15.0,
                }),
            ]"/>
        </record>

    </data>
</odoo>