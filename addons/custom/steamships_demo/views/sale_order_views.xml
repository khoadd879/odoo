<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_sale_order_form_inherit_steamships" model="ir.ui.view">
            <field name="name">sale.order.form.steamships</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_request_discount_approval"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-thumbs-up"
                            invisible="not x_discount_pct or x_discount_pct &lt;= 10 or x_discount_approved">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">Request</span>
                            <span class="o_stat_text">Approval</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="x_division_id"/>
                    <field name="x_branch_id"/>
                </xpath>
                <xpath expr="//page[@name='order_lines']" position="after">
                    <page string="Discount Approval" name="steamships_approval">
                        <group>
                            <group>
                                <field name="x_discount_pct" string="Avg discount %"/>
                                <field name="x_discount_amount"/>
                                <field name="approval_state" widget="badge"
                                       decoration-success="approval_state == 'approved'"
                                       decoration-danger="approval_state == 'rejected'"
                                       decoration-warning="approval_state == 'required'"
                                       decoration-info="approval_state == 'not_required'"/>
                                <field name="x_discount_approved" invisible="1"/>
                            </group>
                        </group>
                        <separator string="Approval History"/>
                        <field name="approval_request_ids" readonly="1">
                            <list>
                                <field name="create_date"/>
                                <field name="requested_by"/>
                                <field name="total_discount_pct"/>
                                <field name="total_discount_amount"/>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'approved'"
                                       decoration-danger="state == 'rejected'"
                                       decoration-warning="state == 'pending'"/>
                                <field name="reviewed_by"/>
                                <field name="review_notes"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_sale_order_approval_request_form" model="ir.ui.view">
            <field name="name">sale.order.approval.request.form</field>
            <field name="model">sale.order.approval.request</field>
            <field name="arch" type="xml">
                <form string="Discount Approval Request">
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button name="action_approve" type="object"
                                string="Approve" class="oe_highlight"
                                invisible="state != 'pending'"/>
                        <button name="action_reject" type="object"
                                string="Reject"
                                invisible="state != 'pending'"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="order_id"/>
                                <field name="requested_by"/>
                                <field name="requested_date"/>
                            </group>
                            <group>
                                <field name="total_discount_pct"/>
                                <field name="total_discount_amount"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <separator string="Justification"/>
                        <field name="reason" placeholder="Why is this discount needed? Customer commitment, volume, competitive..."/>
                        <separator string="Review (Manager)" invisible="state == 'pending'"/>
                        <group invisible="state == 'pending'">
                            <group>
                                <field name="reviewed_by"/>
                                <field name="reviewed_date"/>
                            </group>
                            <group>
                                <field name="review_notes" placeholder="Decision rationale..."/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sale_order_approval_request_tree" model="ir.ui.view">
            <field name="name">sale.order.approval.request.tree</field>
            <field name="model">sale.order.approval.request</field>
            <field name="arch" type="xml">
                <list string="Discount Approvals">
                    <field name="create_date"/>
                    <field name="order_id"/>
                    <field name="requested_by"/>
                    <field name="total_discount_pct"/>
                    <field name="total_discount_amount"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'approved'"
                           decoration-danger="state == 'rejected'"
                           decoration-warning="state == 'pending'"/>
                    <field name="reviewed_by"/>
                </list>
            </field>
        </record>

        <record id="action_sale_order_approval_request" model="ir.actions.act_window">
            <field name="name">Discount Approvals</field>
            <field name="res_model">sale.order.approval.request</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Server action: open sale orders that need attention -->
        <record id="action_quotations_with_onboarding" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,kanban,form,calendar,graph</field>
        </record>

    </data>
</odoo>
