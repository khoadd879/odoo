<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Steamships-branded sale.order PDF report.
             Inherits sale.report_saleorder_document.

             Adds:
             1. Division + Branch row (under informations)
             2. Discount approval banner (yellow alert) if approval required
             3. Payment terms note section (auto from payment_term_id.note)
             4. Discount subtotal badge (color-coded by approval state)

             Header + footer + paperformat come from
             report_header_footer.xml + ir_actions_report_override.xml.
             ============================================================ -->

        <template id="report_saleorder_document_steamships"
                  inherit_id="sale.report_saleorder_document"
                  name="Steamships Sale Order Document">

            <!-- 1. Add division/branch/approval row after the standard
                    informations row (which already shows date, salesperson...) -->
            <xpath expr="//div[@id='informations']" position="after">
                <div class="row mb-3" id="steamships_informations_extra">
                    <div t-if="doc.x_division_id" class="col">
                        <strong>Division</strong>
                        <div t-field="doc.x_division_id.name">Division name</div>
                    </div>
                    <div t-if="doc.x_branch_id" class="col">
                        <strong>Branch</strong>
                        <div t-field="doc.x_branch_id.name">Branch name</div>
                    </div>
                    <div class="col">
                        <strong>Currency</strong>
                        <div t-field="doc.currency_id.name">PGK</div>
                    </div>
                    <div t-if="doc.approval_state and doc.approval_state != 'not_required'"
                         class="col">
                        <strong>Discount Status</strong>
                        <div>
                            <t t-if="doc.approval_state == 'required'">
                                <span style="background-color: #fdd415; color: #002850;
                                             padding: 2px 8px; border-radius: 3px;
                                             font-weight: 700; font-size: 9pt;">
                                    ⚠ Approval Required
                                </span>
                            </t>
                            <t t-if="doc.approval_state == 'approved'">
                                <span style="background-color: #28a745; color: white;
                                             padding: 2px 8px; border-radius: 3px;
                                             font-weight: 700; font-size: 9pt;">
                                    ✓ Approved
                                </span>
                            </t>
                            <t t-if="doc.approval_state == 'rejected'">
                                <span style="background-color: #dc3545; color: white;
                                             padding: 2px 8px; border-radius: 3px;
                                             font-weight: 700; font-size: 9pt;">
                                    ✗ Rejected
                                </span>
                            </t>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- 2. Discount approval banner — shown above line items if
                    discount > 10% and not yet approved -->
            <xpath expr="//table[@class='o_has_total_table table o_main_table table-borderless']"
                   position="before">
                <t t-if="doc.x_discount_pct and doc.x_discount_pct &gt; 10 and not doc.x_discount_approved">
                    <div class="alert alert-warning mb-3" role="alert"
                         style="background-color: #fff3cd; border-left: 4px solid #fdd415;
                                padding: 12px 16px; border-radius: 4px;">
                        <strong style="color: #002850;">
                            ⚠ Discount Approval Required
                        </strong>
                        <p style="margin: 4px 0 0 0; color: #444; font-size: 9pt;">
                            This quotation has an average discount of
                            <strong t-esc="'{:.1f}%'.format(doc.x_discount_pct)">15.0%</strong>,
                            which exceeds the 10% threshold. Sales Manager approval
                            is required before this order can be confirmed.
                        </p>
                    </div>
                </t>
            </xpath>

            <!-- 3. Payment terms + Internal margin note — appended after
                    the totals table (before the closing page div) -->
            <xpath expr="//div[@id='total']" position="after">
                <t t-if="doc.payment_term_id">
                    <div class="mt-4" id="steamships_payment_terms">
                        <h4 style="color: #002850; font-size: 10pt; margin-bottom: 4px;">
                            Payment Terms
                        </h4>
                        <div t-field="doc.payment_term_id.note"
                             style="font-size: 9pt; color: #444;
                                    padding: 8px 12px; background: #f7f7f9;
                                    border-left: 3px solid #fdd415;">
                            Payment terms description
                        </div>
                    </div>
                </t>
                <t t-if="doc.note">
                    <div class="mt-3" id="steamships_order_note">
                        <h4 style="color: #002850; font-size: 10pt; margin-bottom: 4px;">
                            Notes
                        </h4>
                        <div t-field="doc.note" style="font-size: 9pt; color: #444;">
                            Internal note
                        </div>
                    </div>
                </t>
            </xpath>

        </template>

    </data>
</odoo>