<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Top-level Steamships menu -->
        <menuitem id="menu_steamships_root"
                  name="Steamships"
                  sequence="10"/>

        <menuitem id="menu_steamships_dashboard"
                  name="Dashboard"
                  parent="menu_steamships_root"
                  action="crm.crm_lead_action_pipeline"
                  sequence="5"/>

        <menuitem id="menu_steamships_master"
                  name="Master Data"
                  parent="menu_steamships_root"
                  sequence="20"/>

        <menuitem id="menu_steamships_division"
                  name="Divisions"
                  parent="menu_steamships_master"
                  action="action_steamships_division"
                  sequence="10"/>

        <menuitem id="menu_steamships_branch"
                  name="Branches"
                  parent="menu_steamships_master"
                  action="action_steamships_branch"
                  sequence="20"/>

        <record id="action_steamships_pricelist" model="ir.actions.act_window">
            <field name="name">Price Lists</field>
            <field name="res_model">product.pricelist</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_steamships_pricelist"
                  name="Price Lists"
                  parent="menu_steamships_master"
                  action="action_steamships_pricelist"
                  sequence="30"/>

        <menuitem id="menu_steamships_bl"
                  name="Bills of Lading"
                  parent="menu_steamships_root"
                  action="action_bill_of_lading"
                  sequence="50"/>

        <menuitem id="menu_steamships_sales"
                  name="Sales"
                  parent="menu_steamships_root"
                  sequence="30"/>

        <menuitem id="menu_steamships_sale_orders"
                  name="Quotations / Orders"
                  parent="menu_steamships_sales"
                  action="sale.action_quotations_with_onboarding"
                  sequence="10"/>

        <menuitem id="menu_steamships_approvals"
                  name="Discount Approvals"
                  parent="menu_steamships_sales"
                  action="action_sale_order_approval_request"
                  sequence="20"/>

        <menuitem id="menu_steamships_onboarding"
                  name="Customer Onboardings"
                  parent="menu_steamships_master"
                  action="action_crm_lead_steamships_onboarding"
                  sequence="40"/>

        <menuitem id="menu_steamships_ai_root"
                  name="AI Assistant"
                  parent="menu_steamships_root"
                  sequence="15"/>

        <menuitem id="menu_steamships_ai_chat"
                  name="Ask AI"
                  parent="menu_steamships_ai_root"
                  action="action_steamships_ai_chat"
                  sequence="10"/>

        <menuitem id="menu_steamships_ai_chat_log"
                  name="Chat History"
                  parent="menu_steamships_ai_root"
                  action="action_steamships_ai_chat_log"
                  sequence="20"/>

    </data>
</odoo>
