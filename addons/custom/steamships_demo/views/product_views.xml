<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_template_form_inherit_steamships" model="ir.ui.view">
            <field name="name">product.template.form.steamships</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="after">
                    <field name="default_code" string="SKU" readonly="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
