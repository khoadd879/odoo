<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List view -->
        <record id="view_steamships_appointment_slot_tree" model="ir.ui.view">
            <field name="name">steamships.appointment.slot.tree</field>
            <field name="model">steamships.appointment.slot</field>
            <field name="arch" type="xml">
                <list decoration-warning="state=='pending'"
                      decoration-success="state=='confirmed'"
                      decoration-danger="state in ('cancelled','no_show')"
                      decoration-muted="state=='done'">
                    <field name="name"/>
                    <field name="start_datetime"/>
                    <field name="duration_minutes"/>
                    <field name="appointment_type"/>
                    <field name="partner_name"/>
                    <field name="partner_email"/>
                    <field name="assigned_user_id"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_steamships_appointment_slot_form" model="ir.ui.view">
            <field name="name">steamships.appointment.slot.form</field>
            <field name="model">steamships.appointment.slot</field>
            <field name="arch" type="xml">
                <form string="Appointment Slot">
                    <header>
                        <button name="action_confirm" type="object"
                                string="Confirm" class="btn-primary"
                                invisible="state != 'pending'"/>
                        <button name="action_cancel" type="object"
                                string="Cancel"
                                invisible="state in ('done','cancelled','no_show')"/>
                        <button name="action_mark_done" type="object"
                                string="Mark Done"
                                invisible="state != 'confirmed'"/>
                        <button name="action_mark_no_show" type="object"
                                string="No Show"
                                invisible="state != 'confirmed'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="pending,confirmed,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Visitor">
                                <field name="partner_name"/>
                                <field name="partner_email" widget="email"/>
                                <field name="partner_phone" widget="phone"/>
                                <field name="partner_id"/>
                            </group>
                            <group string="Appointment">
                                <field name="appointment_type"/>
                                <field name="duration_minutes"/>
                                <field name="start_datetime"/>
                                <field name="end_datetime" readonly="1"/>
                                <field name="assigned_user_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" placeholder="What does the visitor want to discuss?"/>
                            <field name="internal_notes" placeholder="Staff-only notes"/>
                        </group>
                        <group string="Confirmation"
                               invisible="state == 'pending'">
                            <field name="confirmed_at" readonly="1"/>
                            <field name="cancelled_at" readonly="1"
                                   invisible="state != 'cancelled'"/>
                            <field name="cancellation_reason"
                                   invisible="state != 'cancelled'"/>
                            <field name="confirmation_token" readonly="1"/>
                        </group>
                        <group string="Related Records">
                            <field name="lead_id"/>
                            <field name="calendar_event_id" readonly="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_steamships_appointment_slot_search" model="ir.ui.view">
            <field name="name">steamships.appointment.slot.search</field>
            <field name="model">steamships.appointment.slot</field>
            <field name="arch" type="xml">
                <search>
                    <filter name="pending" string="Pending"
                            domain="[('state', '=', 'pending')]"/>
                    <filter name="confirmed" string="Confirmed"
                            domain="[('state', '=', 'confirmed')]"/>
                    <filter name="upcoming" string="Upcoming"
                            domain="[('start_datetime', '&gt;=', (datetime.now()).strftime('%Y-%m-%d 00:00:00')), ('state', 'in', ['pending', 'confirmed'])]"/>
                    <field name="name"/>
                    <field name="partner_name"/>
                    <field name="partner_email"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_steamships_appointment_slot" model="ir.actions.act_window">
            <field name="name">Appointment Slots</field>
            <field name="res_model">steamships.appointment.slot</field>
            <field name="view_mode">list,form,calendar</field>
            <field name="context">{'search_default_upcoming': 1}</field>
        </record>

    </data>
</odoo>
