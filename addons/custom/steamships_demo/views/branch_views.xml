<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_steamships_branch_tree" model="ir.ui.view">
            <field name="name">steamships.branch.tree</field>
            <field name="model">steamships.branch</field>
            <field name="arch" type="xml">
                <list string="Branches">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="division_id"/>
                    <field name="phone"/>
                    <field name="email"/>
                </list>
            </field>
        </record>

        <record id="view_steamships_branch_form" model="ir.ui.view">
            <field name="name">steamships.branch.form</field>
            <field name="model">steamships.branch</field>
            <field name="arch" type="xml">
                <form string="Branch">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="division_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="manager_id"/>
                            </group>
                        </group>
                        <group>
                            <field name="address"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_steamships_branch" model="ir.actions.act_window">
            <field name="name">Branches</field>
            <field name="res_model">steamships.branch</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_steamships_branch_in_division" model="ir.actions.act_window">
            <field name="name">Branches</field>
            <field name="res_model">steamships.branch</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('division_id', '=', active_id)]</field>
        </record>
    </data>
</odoo>
