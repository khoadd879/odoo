<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_steamships_division_tree" model="ir.ui.view">
            <field name="name">steamships.division.tree</field>
            <field name="model">steamships.division</field>
            <field name="arch" type="xml">
                <list string="Divisions">
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="branch_count"/>
                </list>
            </field>
        </record>

        <record id="view_steamships_division_form" model="ir.ui.view">
            <field name="name">steamships.division.form</field>
            <field name="model">steamships.division</field>
            <field name="arch" type="xml">
                <form string="Division">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_branches"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-building">
                                <field name="branch_count" widget="statinfo" string="Branches"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="sequence"/>
                                <field name="color" widget="color"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Branches">
                                <field name="branch_ids" readonly="1"/>
                            </page>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_steamships_division" model="ir.actions.act_window">
            <field name="name">Divisions</field>
            <field name="res_model">steamships.division</field>
            <field name="view_mode">list,form</field>
            <field name="help">Steamships business divisions: Shipping, Property, Hotels, Logistics</field>
        </record>
    </data>
</odoo>
