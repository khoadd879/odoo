<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Backend menu action: opens a client action that loads the chat widget
             inside the Odoo backend (not the public website). -->
        <record id="action_steamships_ai_chat" model="ir.actions.client">
            <field name="name">Steamships AI Assistant</field>
            <field name="tag">steamships_ai_chat</field>
            <field name="target">main</field>
        </record>

        <!-- Window action fallback: opens a dedicated chatter/log of past AI sessions.
             For Day 3-4 this is just a menu item; logging comes in G13. -->
        <record id="action_steamships_ai_chat_log" model="ir.actions.act_window">
            <field name="name">AI Chat History</field>
            <field name="res_model">mail.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('body', 'like', '[AI Chat%')]</field>
            <field name="help">Past AI chat sessions logged to chatter (filter by body prefix '[AI Chat').</field>
        </record>

        <!-- Server action: open chat as standalone URL in a new window.
             Useful when staff wants chat on a second monitor during demos. -->
        <record id="action_steamships_ai_chat_window" model="ir.actions.act_url">
            <field name="name">Open Chat in New Window</field>
            <field name="url">/web#action=steamships_demo.action_steamships_ai_chat</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
