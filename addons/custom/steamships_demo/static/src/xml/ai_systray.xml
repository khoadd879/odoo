<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- AI systray entry: small icon in navbar, mimics Odoo 19 EE AI button -->
    <t t-name="steamships_demo.AISystray" owl="1">
        <button class="o_ssc_systray_btn btn btn-light position-relative"
                t-on-click="onClick"
                title="Steamships AI Assistant"
                aria-label="Open Steamships AI Assistant"
                style="border-radius:6px; padding:4px 10px; display:flex; align-items:center; gap:6px;">
            <i class="fa fa-comments text-primary" style="font-size:16px;"></i>
            <span class="fw-semibold text-primary" style="font-size:13px;">AI</span>
        </button>
    </t>

    <!-- Chat dialog -->
    <t t-name="steamships_demo.AIDialog" owl="1">
        <Dialog title="props.title" size="props.size">
            <div class="o_ssc_dialog d-flex flex-column bg-view" style="height:500px;">

                <!-- Header: mode toggle -->
                <div class="o_ssc_header d-flex align-items-center justify-content-between p-2 text-white"
                     style="background:#714B67;">
                    <div class="d-flex align-items-center" style="gap:12px;">
                        <small class="text-white-50">Mode:</small>
                        <div class="btn-group btn-group-sm" role="group">
                            <button t-on-click="switchStaff"
                                    t-attf-class="btn {{ state.mode === 'staff' ? 'btn-light' : 'btn-outline-light'}}">
                                Staff
                            </button>
                            <button t-on-click="switchClient"
                                    t-attf-class="btn {{ state.mode === 'client' ? 'btn-light' : 'btn-outline-light'}}">
                                Client
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Messages -->
                <div class="o_ssc_log flex-grow-1 overflow-auto p-3 bg-light"
                     style="min-height:0;" t-ref="log">
                    <div t-foreach="state.messages" t-as="msg" t-key="msg.id"
                         t-attf-class="mb-2 d-flex {{ msg.role === 'user' ? 'justify-content-end' : 'justify-content-start'}}">
                        <div style="max-width:85%;">
                            <div t-attf-class="p-2 rounded {{ msg.role === 'user' ? 'text-white' : 'bg-white border'}}"
                                 t-attf-style="{{ msg.role === 'user' ? 'background:#714B67;' : ''}} white-space:pre-wrap; line-height:1.4;">
                                <t t-esc="msg.content"/>
                            </div>
                            <div t-if="msg.sources and msg.sources.length" class="small text-muted mt-1 text-start"
                                 style="font-size:11px;">
                                <i class="fa fa-book"/> Sources: <t t-foreach="msg.sources" t-as="s" t-key="s"><t t-esc="s"/> <t t-if="!s_last">|</t> </t>
                            </div>
                        </div>
                    </div>
                    <div t-if="state.busy" class="text-muted small ps-2">
                        <i class="fa fa-circle-o-notch fa-spin"/> Thinking…
                    </div>
                </div>

                <!-- Input row -->
                <div class="o_ssc_input d-flex p-2 border-top" style="gap:8px; background:#fff;">
                    <input type="text"
                           class="form-control"
                           t-att-placeholder="state.mode === 'staff'
                               ? 'Ask about FCL, KYC, discount approval, branches…'
                               : 'Ask about onboarding, KYC documents, what to expect…'"
                           t-model="state.draft"
                           t-on-keydown="onKey"
                           t-att-disabled="state.busy"/>
                    <button class="btn btn-primary" t-on-click="send"
                            t-att-disabled="state.busy or !state.draft.trim()">
                        <i class="fa fa-paper-plane-o"/> Send
                    </button>
                </div>
            </div>
        </Dialog>
    </t>

</templates>