<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="steamships_demo.ChatWidget" owl="1">
        <div class="o_ssc_root h-100 d-flex flex-column bg-view">
            <div class="o_ssc_header d-flex align-items-center justify-content-between p-2 text-white"
                 style="background:#714B67; border-radius:6px 6px 0 0;">
                <div><strong>Steamships AI Assistant</strong></div>
                <div class="d-flex align-items-center" style="gap:12px;">
                    <div class="btn-group btn-group-sm" role="group">
                        <button t-on-click="switchStaff"
                                t-attf-class="btn {{ state.mode === 'staff' ? 'btn-light' : 'btn-outline-light'}}">
                            Staff
                        </button>
                        <button t-on-click="switchClient"
                                t-attf-class="btn {{ state.mode === 'client' ? 'btn-light' : 'btn-outline-light'}}">
                            Client
                        </button>
                    </div>
                </div>
            </div>

            <div class="o_ssc_log flex-grow-1 overflow-auto p-3 bg-light"
                 style="border:1px solid #ddd;border-top:0;min-height:300px;" t-ref="log">
                <div t-foreach="state.messages" t-as="msg" t-key="msg.id"
                     t-attf-class="mb-2 d-flex {{ msg.role === 'user' ? 'justify-content-end' : 'justify-content-start'}}">
                    <div t-attf-class="p-2 rounded {{ msg.role === 'user' ? 'text-white' : 'bg-white border'}}"
                         t-attf-style="{{ msg.role === 'user' ? 'background:#714B67;' : ''}} max-width:85%; white-space:pre-wrap; line-height:1.4;">
                        <t t-esc="msg.content"/>
                        <div t-if="msg.sources and msg.sources.length" class="small text-muted mt-1">
                            Sources: <t t-foreach="msg.sources" t-as="s" t-key="s"><t t-esc="s"/> <t t-if="!s_last">|</t> </t>
                        </div>
                    </div>
                </div>
                <div t-if="state.busy" class="text-muted small">Thinking…</div>
            </div>

            <div class="o_ssc_input d-flex p-2" style="gap:8px;">
                <input type="text"
                       class="form-control"
                       t-att-placeholder="state.mode === 'staff'
                           ? 'Ask about FCL, KYC, discount approval, branches…'
                           : 'Ask about onboarding, KYC documents, what to expect…'"
                       t-model="state.draft"
                       t-on-keydown="onKey"
                       disabled="state.busy"/>
                <button class="btn btn-primary" t-on-click="send" disabled="state.busy or !state.draft.trim()">
                    Send
                </button>
            </div>
        </div>
    </t>
</templates>
