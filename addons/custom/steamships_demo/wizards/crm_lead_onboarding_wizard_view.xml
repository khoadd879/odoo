<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_crm_lead_steamships_onboarding_wizard_form" model="ir.ui.view">
            <field name="name">crm.lead.steamships.onboarding.wizard.form</field>
            <field name="model">crm.lead.steamships.onboarding.wizard</field>
            <field name="arch" type="xml">
                <form string="Start Customer Onboarding">
                    <group>
                        <field name="lead_id" readonly="1"/>
                        <field name="industry" widget="selection"/>
                        <field name="service_needed" widget="selection"/>
                        <field name="company_size" widget="selection"/>
                    </group>
                    <footer>
                        <button name="action_create_onboarding"
                                string="Start Onboarding"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
