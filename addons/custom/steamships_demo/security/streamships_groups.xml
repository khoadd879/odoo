<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ==========================================
             Steamships-specific groups
             (kế thừa từ base.group_user để có sẵn portal/internal)
             ========================================== -->
        <record id="group_steamships_user" model="res.groups">
            <field name="name">Steamships / User</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">
                Nhân viên Steamships nội bộ. Đọc dashboard, master data.
                Không thấy giá nội bộ, không tạo lead.
            </field>
        </record>

        <record id="group_steamships_sales" model="res.groups">
            <field name="name">Steamships / Sales</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="implied_ids" eval="[(4, ref('group_steamships_user'))]"/>
            <field name="comment">
                Nhân viên Sales: tạo lead, xem giá nội bộ, tạo quotation.
            </field>
        </record>

        <record id="group_steamships_manager" model="res.groups">
            <field name="name">Steamships / Manager</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="implied_ids" eval="[(4, ref('group_steamships_sales'))]"/>
            <field name="comment">
                Quản lý: phê duyệt discount, xem báo cáo tài chính,
                quản lý KYC, phân quyền nhân viên.
            </field>
        </record>

    </data>
</odoo>
