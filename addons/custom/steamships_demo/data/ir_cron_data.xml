<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Cleanup old chatbot sessions (older than 90 days).
             Odoo 18 ir.cron uses cron_name, interval_number, interval_type.
             No numbercall field — repeats indefinitely.
             ============================================================ -->
        <record id="ir_cron_chatbot_session_cleanup" model="ir.cron">
            <field name="name">Steamships: Cleanup old chatbot sessions</field>
            <field name="model_id" ref="model_steamships_chatbot_session"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_sessions(days=90)</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Mark confirmed appointments as 'done' 1 day after end_datetime -->
        <record id="ir_cron_appointment_mark_done" model="ir.cron">
            <field name="name">Steamships: Mark past appointments as done</field>
            <field name="model_id" ref="model_steamships_appointment_slot"/>
            <field name="state">code</field>
            <field name="code">model._cron_mark_past_done()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
