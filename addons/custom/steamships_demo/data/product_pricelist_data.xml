<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="pricelist_pgk_standard" model="product.pricelist">
            <field name="name">PGK Standard</field>
            <field name="currency_id" ref="base.PGK"/>
            <field name="company_id" ref="res_company_steamships"/>
        </record>
        <record id="pricelist_usd_corporate" model="product.pricelist">
            <field name="name">USD Corporate</field>
            <field name="currency_id" ref="base.USD"/>
            <field name="company_id" ref="res_company_steamships"/>
        </record>
        <record id="pricelist_pgk_vip" model="product.pricelist">
            <field name="name">PGK VIP (key accounts)</field>
            <field name="currency_id" ref="base.PGK"/>
            <field name="company_id" ref="res_company_steamships"/>
        </record>

        <!-- USD Corporate = 10% lower than PGK list (in PGK base) -->
        <record model="product.pricelist.item" id="pricelist_item_usd_fcl20">
            <field name="pricelist_id" ref="pricelist_usd_corporate"/>
            <field name="product_id" ref="product_fcl_20"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">5</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_usd_fcl40">
            <field name="pricelist_id" ref="pricelist_usd_corporate"/>
            <field name="product_id" ref="product_fcl_40"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">5</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_usd_stdroom">
            <field name="pricelist_id" ref="pricelist_usd_corporate"/>
            <field name="product_id" ref="product_std_room"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">8</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_usd_suite">
            <field name="pricelist_id" ref="pricelist_usd_corporate"/>
            <field name="product_id" ref="product_suite_room"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">8</field>
        </record>

        <!-- VIP = 12% off standard -->
        <record model="product.pricelist.item" id="pricelist_item_vip_fcl20">
            <field name="pricelist_id" ref="pricelist_pgk_vip"/>
            <field name="product_id" ref="product_fcl_20"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">12</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_vip_fcl40">
            <field name="pricelist_id" ref="pricelist_pgk_vip"/>
            <field name="product_id" ref="product_fcl_40"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">12</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_vip_suite">
            <field name="pricelist_id" ref="pricelist_pgk_vip"/>
            <field name="product_id" ref="product_suite_room"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">15</field>
        </record>
        <record model="product.pricelist.item" id="pricelist_item_vip_offa">
            <field name="pricelist_id" ref="pricelist_pgk_vip"/>
            <field name="product_id" ref="product_office_a"/>
            <field name="compute_price">formula</field>
            <field name="base">list_price</field>
            <field name="price_discount">10</field>
        </record>

    </data>
</odoo>
