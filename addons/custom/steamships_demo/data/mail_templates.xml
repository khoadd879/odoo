<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Onboarding confirmation email
             Sent to customer (res.partner email) when onboarding form submitted.
             Used by controllers/onboarding.py via template.send_mail(lead.id)
             ============================================================ -->
        <record id="mail_template_onboarding_thanks" model="mail.template">
            <field name="name">Steamships Onboarding — Thank you</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="subject">Welcome to Steamships — Reference: {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or 'noreply@steamships.com.pg') }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
    <div style="background: linear-gradient(135deg, #CE1126 0%, #000000 50%, #FCD116 100%); color: white; padding: 24px; border-radius: 8px 8px 0 0;">
        <h1 style="margin: 0; font-size: 24px;">Steamships Trading Company (PNG)</h1>
        <p style="margin: 8px 0 0; opacity: .9;">Pacific's leading diversified group</p>
    </div>

    <div style="background: white; padding: 24px; border: 1px solid #e0e0e0; border-top: 0; border-radius: 0 0 8px 8px;">
        <h2 style="color: #714B67; margin-top: 0;">Thank you, {{ object.contact_name or 'Valued Client' }}!</h2>

        <p>We have received your inquiry and our team is reviewing your requirements.</p>

        <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
            <tr style="background: #f7f7f9;">
                <td style="padding: 8px 12px; font-weight: 600; width: 35%;">Reference</td>
                <td style="padding: 8px 12px;">{{ object.name }}</td>
            </tr>
            <tr>
                <td style="padding: 8px 12px; font-weight: 600;">Company</td>
                <td style="padding: 8px 12px;">{{ object.partner_id.name }}</td>
            </tr>
            <tr style="background: #f7f7f9;">
                <td style="padding: 8px 12px; font-weight: 600;">Sales contact</td>
                <td style="padding: 8px 12px;">{{ object.user_id.name or 'Our sales team' }}</td>
            </tr>
        </table>

        <h3 style="color: #714B67;">What happens next</h3>
        <ol>
            <li><strong>Within 24 hours</strong> — our sales team will contact you to confirm documents.</li>
            <li><strong>Within 3 business days</strong> — you'll receive a KYC checklist to complete.</li>
            <li><strong>Within 1 week</strong> — once KYC is approved, we'll prepare a quote.</li>
        </ol>

        <p style="margin-top: 24px; font-size: 13px; color: #666;">
            Steamships Trading Company (PNG) Ltd<br/>
            Champion Parade, Port Moresby, Papua New Guinea<br/>
            Tel: +675 322 0800 · Email: info@steamships.com.pg
        </p>
    </div>
</div>
            </field>
            <field name="lang">{{ object.partner_id.lang or 'en_US' }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- ============================================================
             Booking confirmation email — with ICS attachment
             Sent when visitor confirms appointment slot.
             Used by models/appointment_slot.py action_confirm()
             ============================================================ -->
        <record id="mail_template_booking_confirmed" model="mail.template">
            <field name="name">Steamships Booking — Confirmed</field>
            <field name="model_id" ref="model_steamships_appointment_slot"/>
            <field name="subject">Booking confirmed: {{ object.name }} on {{ object.start_datetime }}</field>
            <field name="email_from">{{ (object.company_id.email or 'noreply@steamships.com.pg') }}</field>
            <field name="email_to">{{ object.partner_email }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
    <div style="background: #012f5c; color: white; padding: 24px; border-radius: 8px 8px 0 0; border-bottom: 3px solid #fdd415;">
        <h1 style="margin: 0; font-size: 22px;">Steamships — Booking Confirmed</h1>
    </div>
    <div style="background: white; padding: 24px; border: 1px solid #e0e0e0; border-top: 0; border-radius: 0 0 8px 8px;">
        <p>Hello {{ object.partner_name }},</p>
        <p>Your appointment has been confirmed. Details:</p>
        <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
            <tr style="background: #f7f7f9;">
                <td style="padding: 8px; font-weight: 600;">Type</td>
                <td style="padding: 8px;">{{ dict(object._fields['appointment_type'].selection).get(object.appointment_type) }}</td>
            </tr>
            <tr>
                <td style="padding: 8px; font-weight: 600;">Date / Time</td>
                <td style="padding: 8px;">{{ object.start_datetime }} (PNG time, GMT+10)</td>
            </tr>
            <tr style="background: #f7f7f9;">
                <td style="padding: 8px; font-weight: 600;">Duration</td>
                <td style="padding: 8px;">{{ object.duration_minutes }} minutes</td>
            </tr>
            <tr>
                <td style="padding: 8px; font-weight: 600;">Host</td>
                <td style="padding: 8px;">{{ object.assigned_user_id.name or 'Sales team' }}</td>
            </tr>
        </table>
        <p>An ICS calendar file is attached. Add it to your calendar app.</p>
        <p style="font-size: 13px; color: #666;">
            Steamships Trading Company (PNG) Ltd ·
            Tel: +675 322 0800 · info@steamships.com.pg
        </p>
    </div>
</div>
            </field>
            <field name="lang">en_US</field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
