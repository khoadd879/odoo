<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="lead_partners_demo" model="res.partner">
            <field name="name">Marienburg Mining Ltd</field>
            <field name="is_company" eval="True"/>
            <field name="country_id" ref="base.pg"/>
            <field name="email">ops@marienburg.pg</field>
        </record>
        <record id="lead_partner_ok" model="res.partner">
            <field name="name">Ok Tedi Mining</field>
            <field name="is_company" eval="True"/>
            <field name="country_id" ref="base.pg"/>
            <field name="email">logistics@oktedi.pg</field>
        </record>
        <record id="lead_partner_bsp" model="res.partner">
            <field name="name">Bank South Pacific</field>
            <field name="is_company" eval="True"/>
            <field name="country_id" ref="base.pg"/>
            <field name="email">admin@bsp.com.pg</field>
        </record>
        <record id="lead_partner_embassy" model="res.partner">
            <field name="name">Australian High Commission</field>
            <field name="is_company" eval="True"/>
            <field name="country_id" ref="base.pg"/>
            <field name="email">property@ahc.gov.au</field>
        </record>

        <!-- Lead 1: Shipping new prospect -->
        <record id="lead_001" model="crm.lead">
            <field name="name">FCL monthly contract - Marienburg Mining</field>
            <field name="partner_id" ref="lead_partners_demo"/>
            <field name="user_id" ref="user_ship_sales"/>
            <field name="team_id" ref="crm_team_shipping"/>
            <field name="type">opportunity</field>
            <field name="priority">2</field>
            <field name="expected_revenue">2500000.0</field>
            <field name="probability">30</field>
            <field name="stage_id" ref="stage_lead"/>
        </record>

        <!-- Lead 2: Property - office lease -->
        <record id="lead_002" model="crm.lead">
            <field name="name">Grade A office 350 sqm - AHC</field>
            <field name="partner_id" ref="lead_partner_embassy"/>
            <field name="user_id" ref="user_prop_sales"/>
            <field name="team_id" ref="crm_team_property"/>
            <field name="type">opportunity</field>
            <field name="priority">1</field>
            <field name="expected_revenue">1200000.0</field>
            <field name="probability">50</field>
            <field name="stage_id" ref="stage_qualified"/>
        </record>

        <!-- Lead 3: Hotels - corporate rate -->
        <record id="lead_003" model="crm.lead">
            <field name="name">Annual corporate rate - BSP</field>
            <field name="partner_id" ref="lead_partner_bsp"/>
            <field name="user_id" ref="user_hotel_sales"/>
            <field name="team_id" ref="crm_team_hotels"/>
            <field name="type">opportunity</field>
            <field name="priority">0</field>
            <field name="expected_revenue">450000.0</field>
            <field name="probability">70</field>
            <field name="stage_id" ref="stage_onboarding_docs"/>
        </record>

        <!-- Lead 4: Logistics -->
        <record id="lead_004" model="crm.lead">
            <field name="name">Customs + inland for Ok Tedi</field>
            <field name="partner_id" ref="lead_partner_ok"/>
            <field name="user_id" ref="user_sales_lead"/>
            <field name="team_id" ref="crm_team_logistics"/>
            <field name="type">opportunity</field>
            <field name="priority">1</field>
            <field name="expected_revenue">850000.0</field>
            <field name="probability">20</field>
            <field name="stage_id" ref="stage_quoted"/>
        </record>

        <!-- Lead 5: Won -->
        <record id="lead_005" model="crm.lead">
            <field name="name">LCL weekly - existing miner</field>
            <field name="partner_id" ref="lead_partner_ok"/>
            <field name="user_id" ref="user_ship_sales"/>
            <field name="team_id" ref="crm_team_shipping"/>
            <field name="type">opportunity</field>
            <field name="expected_revenue">320000.0</field>
            <field name="probability">100</field>
            <field name="stage_id" ref="stage_won"/>
        </record>
    </data>
</odoo>
