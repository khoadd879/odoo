<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 5 pipeline stages per DOCX B2 nguyên văn:
             Lead → Qualified → Onboarding Docs → Quoted → Won / Lost
             Last stage "Won / Lost" = single stage, is_won flag distinguishes outcome. -->
        <record id="stage_lead" model="crm.stage">
            <field name="name">Lead</field>
            <field name="sequence">10</field>
            <field name="is_won" eval="False"/>
        </record>

        <record id="stage_qualified" model="crm.stage">
            <field name="name">Qualified</field>
            <field name="sequence">20</field>
            <field name="is_won" eval="False"/>
        </record>

        <record id="stage_onboarding_docs" model="crm.stage">
            <field name="name">Onboarding Docs</field>
            <field name="sequence">30</field>
            <field name="is_won" eval="False"/>
        </record>

        <record id="stage_quoted" model="crm.stage">
            <field name="name">Quoted</field>
            <field name="sequence">40</field>
            <field name="is_won" eval="False"/>
        </record>

        <record id="stage_won" model="crm.stage">
            <field name="name">Won</field>
            <field name="sequence">50</field>
            <field name="is_won" eval="True"/>
        </record>

        <record id="stage_lost" model="crm.stage">
            <field name="name">Lost</field>
            <field name="sequence">60</field>
            <field name="is_won" eval="False"/>
        </record>

    </data>
</odoo>
