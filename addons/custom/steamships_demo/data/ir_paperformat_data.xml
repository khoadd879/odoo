<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Steamships A4 paperformat — used by sale.action_report_saleorder
             (override in ir_actions_report_override.xml).
             margin_top=45mm leaves room for branded header (logo + navy band
             + gold accent line). Smaller side margins for wider tables.
             ============================================================ -->
        <record id="paperformat_steamships" model="report.paperformat">
            <field name="name">Steamships A4</field>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">45</field>
            <field name="margin_bottom">25</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">35</field>
            <field name="dpi">90</field>
        </record>

    </data>
</odoo>